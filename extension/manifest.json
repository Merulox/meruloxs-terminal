{
  "manifest_version": 3,
  "name": "merulox tweet seeder",
  "version": "1.1",
  "description": "Seeds the writing page with fresh X posts via DOM scraping",
  "permissions": ["cookies", "storage", "scripting", "tabs"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "http://localhost:4321/*",
    "https://merulox.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "tweet seeder"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/merulox", "https://x.com/merulox/*"],
      "js": ["x_profile.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:4321/*",
        "https://merulox.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
