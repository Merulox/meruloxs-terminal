{
  "manifest_version": 3,
  "name": "merulox tweet seeder",
  "version": "1.9",
  "description": "Seeds the writing page with fresh X posts, and feeds the build-log with ChatGPT history",
  "permissions": ["alarms", "cookies", "storage", "scripting", "tabs"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "http://localhost:4321/*",
    "http://localhost:47832/*",
    "https://merulox.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "tweet seeder"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["chatgpt_history.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:4321/*",
        "https://merulox.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
