---
import Layout from "../layouts/Layout.astro";
import { employerNavItems } from "../data/employerNav";

const focusAreas = [
	"AI infrastructure",
	"automation pipelines",
	"commerce and product systems",
	"full-stack development",
	"technical operations",
];

const usefulWhen = [
	"manual workflows need automation",
	"ambiguous systems need to be mapped and built",
	"AI needs to be integrated into real operations",
	"internal tooling matters more than presentation",
	"fast prototyping and iteration are valuable",
];
---

<Layout
	title="for employers | MERULOX"
	description="Software developer and AI systems builder focused on automation, internal tooling, and technical operations."
	homepage={true}
	noindex={true}
>
	<style>
		.employer-home {
			width: min(100%, 760px);
			margin: 0 auto;
			padding: 64px 24px 52px;
		}

		.employer-nav {
			display: flex;
			flex-wrap: wrap;
			gap: 16px;
			justify-content: flex-end;
			margin-bottom: 72px;
			font-family: "SFMono-Regular", Consolas, monospace;
			font-size: 12px;
		}

		.employer-nav a {
			color: var(--muted);
			text-decoration: none;
		}

		.employer-nav a:hover {
			color: var(--accent);
		}

		.employer-nav a::before {
			content: ">";
			color: var(--accent);
			margin-right: 5px;
			opacity: 0;
		}

		.employer-nav a.kbd-cursor {
			color: var(--text);
		}

		.employer-nav a.kbd-cursor::before {
			opacity: 1;
		}

		.employer-hero {
			min-height: min(520px, calc(100vh - 260px));
			display: flex;
			flex-direction: column;
			justify-content: center;
			padding-bottom: 48px;
		}

		.employer-wordmark {
			font-family: "VT323", monospace;
			font-size: 76px;
			font-weight: 400;
			letter-spacing: 0.08em;
			line-height: 0.9;
			margin: 0 0 14px;
			color: var(--text);
		}

		.employer-role {
			color: var(--accent);
			font-family: "SFMono-Regular", Consolas, monospace;
			font-size: 13px;
			margin-bottom: 24px;
		}

		.employer-thesis {
			font-size: 18px;
			line-height: 1.55;
			max-width: 54ch;
		}

		.focus-block {
			margin-top: 30px;
		}

		.employer-label {
			display: block;
			color: var(--muted);
			font-family: "SFMono-Regular", Consolas, monospace;
			font-size: 11px;
			margin-bottom: 8px;
		}

		.focus-list,
		.useful-list {
			list-style: none;
			padding: 0;
			display: grid;
			gap: 5px;
			color: var(--muted);
			font-size: 13px;
		}

		.focus-list li::before,
		.useful-list li::before {
			content: ">";
			color: var(--accent);
			margin-right: 9px;
			font-family: "SFMono-Regular", Consolas, monospace;
		}

		.employer-open {
			margin-top: 28px;
			color: var(--muted);
			font-size: 13px;
			max-width: 62ch;
		}

		.employer-actions {
			display: flex;
			flex-wrap: wrap;
			align-items: center;
			gap: 18px;
			margin-top: 30px;
			font-family: "SFMono-Regular", Consolas, monospace;
			font-size: 12px;
		}

		.employer-actions a {
			text-decoration: none;
		}

		.primary-action {
			color: var(--bg);
			background: var(--accent);
			padding: 7px 11px;
		}

		.secondary-action {
			color: var(--muted);
			padding: 7px 11px;
		}

		.employer-actions a.kbd-cursor {
			box-shadow: inset 0 0 0 1px var(--accent);
		}

		.secondary-action.kbd-cursor {
			color: var(--text);
		}

		.signal-block,
		.useful-block {
			border-top: 1px solid var(--line);
			padding-top: 22px;
			margin-top: 42px;
		}

		.signal-block p {
			color: var(--text);
			font-size: 13px;
			max-width: 60ch;
		}

		.useful-block {
			margin-top: 24px;
			padding-bottom: 40px;
		}

		@media (max-width: 600px) {
			.employer-home {
				padding: 32px 20px 40px;
			}

			.employer-nav {
				justify-content: flex-start;
				margin-bottom: 52px;
			}

			.employer-hero {
				min-height: auto;
				padding-bottom: 28px;
			}

			.employer-wordmark {
				font-size: 58px;
			}

			.employer-thesis {
				font-size: 16px;
			}
		}
	</style>

	<main class="employer-home">
		<nav class="employer-nav" aria-label="Employer navigation">
			{
				employerNavItems.map((item) => (
					<a class="landing-kbd" href={item.href}>{item.label}</a>
				))
			}
		</nav>

		<section class="employer-hero">
			<h1 class="employer-wordmark">MERULOX</h1>
			<p class="employer-role">Software Developer & AI Systems Builder</p>
			<p class="employer-thesis">
				I build automation systems, AI workflows, and internal tools that reduce
				manual work and accelerate execution.
			</p>

			<div class="focus-block">
				<span class="employer-label">Focused on:</span>
				<ul class="focus-list">
					{focusAreas.map((area) => <li>{area}</li>)}
				</ul>
			</div>

			<p class="employer-open">
				Open to software engineering, AI engineering, automation engineering,
				internal tooling, and technical product roles.
			</p>

			<div class="employer-actions">
				<a class="primary-action landing-kbd" href="/employers/projects">View projects</a>
				<a class="secondary-action landing-kbd" href="/employers/contact">Contact</a>
			</div>
		</section>

		<section class="signal-block">
			<span class="employer-label">Current signal</span>
			<p>
				Currently shipping an EDC retail storefront, SMS automation systems,
				and personal agent infrastructure.
			</p>
		</section>

		<section class="useful-block">
			<span class="employer-label">Useful in roles where:</span>
			<ul class="useful-list">
				{usefulWhen.map((item) => <li>{item}</li>)}
			</ul>
		</section>
	</main>

	<script>
		const links = Array.from(document.querySelectorAll<HTMLElement>(".landing-kbd"));
		let active = links.findIndex((link) => link.classList.contains("primary-action"));
		if (active < 0) active = 0;

		function setActive(index: number) {
			links.forEach((link, i) => link.classList.toggle("kbd-cursor", i === index));
			active = index;
		}

		setActive(active);
		links.forEach((link, index) => {
			link.addEventListener("mouseenter", () => setActive(index));
			link.addEventListener("focus", () => setActive(index));
		});

		document.addEventListener("keydown", (event) => {
			if (event.ctrlKey || event.metaKey || event.altKey) return;
			if (event.key === "ArrowRight" || event.key === "l" || event.key === "ArrowDown" || event.key === "j") {
				event.preventDefault();
				setActive((active + 1) % links.length);
			} else if (event.key === "ArrowLeft" || event.key === "h" || event.key === "ArrowUp" || event.key === "k") {
				event.preventDefault();
				setActive((active - 1 + links.length) % links.length);
			} else if (event.key === "Enter" && !links.includes(document.activeElement as HTMLElement)) {
				event.preventDefault();
				links[active].click();
			}
		});
	</script>
</Layout>
