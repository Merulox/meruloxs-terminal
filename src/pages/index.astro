---
import Layout from "../layouts/Layout.astro";
---

<Layout
	title="MERULOX"
	description=">merulox's terminal"
	homepage={true}
>
	<div class="home">
		<div class="home-inner">
			<h1 class="wordmark">MERULOX</h1>
			<nav class="selector" id="selector" aria-label="Navigation">
				<a class="sel-item" href="/work" data-index="0">
					<span class="sel-arrow" aria-hidden="true">&gt;</span>
					<span class="sel-label">projects</span>
				</a>
				<a class="sel-item" href="/thinking" data-index="1">
					<span class="sel-arrow" aria-hidden="true">&gt;</span>
					<span class="sel-label">writing</span>
				</a>
				<a class="sel-item" href="/music" data-index="2">
					<span class="sel-arrow" aria-hidden="true">&gt;</span>
					<span class="sel-label">music</span>
				</a>
				<a class="sel-item" href="/reading" data-index="3">
					<span class="sel-arrow" aria-hidden="true">&gt;</span>
					<span class="sel-label">reading</span>
				</a>
				<a class="sel-item" href="/links" data-index="4">
					<span class="sel-arrow" aria-hidden="true">&gt;</span>
					<span class="sel-label">links</span>
				</a>
				<a class="sel-item" href="/log" data-index="5">
					<span class="sel-arrow" aria-hidden="true">&gt;</span>
					<span class="sel-label">log</span>
				</a>
			</nav>
		</div>
	</div>

	<script>
		const items = Array.from(document.querySelectorAll(".sel-item"));
		let active = 0;

		function setActive(i) {
			items.forEach((el, idx) => el.classList.toggle("active", idx === i));
			active = i;
		}

		setActive(0);

		items.forEach((item, idx) => {
			item.addEventListener("mouseenter", () => setActive(idx));
		});

		document.addEventListener("keydown", (e) => {
			if (e.ctrlKey || e.metaKey || e.altKey) return; // let browser shortcuts through
			if (e.key === "ArrowDown" || e.key === "j") {
				e.preventDefault();
				setActive((active + 1) % items.length);
			} else if (e.key === "ArrowUp" || e.key === "k") {
				e.preventDefault();
				setActive((active - 1 + items.length) % items.length);
			} else if (e.key === "Enter") {
				items[active].click();
			}
		});
	</script>
</Layout>
