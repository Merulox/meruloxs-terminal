---
import Layout from "../layouts/Layout.astro";
import tweetData from "../data/tweets.json";

type ThreadPost = {
	text: string;
	timestamp?: string;
	url: string;
	author?: string;
};

type Tweet = {
	text: string;
	date: string;
	timestamp?: string;
	url: string;
	author?: string;
	isReply?: boolean;
	replyTo?: string;
	replyToUrl?: string;
	replyThread?: ThreadPost[];
	media?: string[];
};

function orchestrateTweets(input: Tweet[]) {
	const replies = new Map<string, Tweet[]>();
	const roots: Tweet[] = [];
	const urls = new Set(input.map((tweet) => tweet.url));

	for (const tweet of input) {
		if (tweet.isReply && tweet.replyToUrl && urls.has(tweet.replyToUrl)) {
			replies.set(tweet.replyToUrl, [...(replies.get(tweet.replyToUrl) ?? []), tweet]);
		} else {
			roots.push(tweet);
		}
	}

	const flattenThread = (tweet: Tweet): Tweet[] => [
		tweet,
		...(replies.get(tweet.url) ?? []).flatMap(flattenThread),
	];

	return roots.flatMap(flattenThread);
}

const tweets = orchestrateTweets(((tweetData.tweets ?? []) as Tweet[])
	.filter((tweet) => tweet.text && tweet.url)
	.slice(0, 300));
const ownTweetUrls = new Set(tweets.map((tweet) => tweet.url));
const TWEET_PAGE_SIZE = 100;

function formatTweetTimestamp(tweet: Tweet) {
	if (!tweet.timestamp) return tweet.date;
	return new Intl.DateTimeFormat("en-CA", {
		timeZone: "America/Toronto",
		year: "numeric",
		month: "2-digit",
		day: "2-digit",
		hour: "2-digit",
		minute: "2-digit",
		hour12: false,
	}).format(new Date(tweet.timestamp)).replace(",", "");
}

function externalReplyThread(tweet: Tweet) {
	return (tweet.replyThread ?? []).filter((post) => !ownTweetUrls.has(post.url));
}
---

<style is:global>
	.writing-section .work-item + .work-item {
		border-top-color: var(--faint);
	}
	.tweet-item {
		position: relative;
	}
	.tweets-viewport {
		height: min(52vh, 460px);
		min-height: 340px;
		overflow-y: auto;
		padding-right: 10px;
		position: relative;
		scrollbar-width: none;
	}
	.tweets-viewport::-webkit-scrollbar {
		display: none;
	}
	.tweets-scroll-frame {
		position: relative;
	}
	.tweets-scroll-frame::after {
		background: linear-gradient(to bottom, transparent, var(--bg));
		bottom: 0;
		content: "";
		height: 56px;
		left: 0;
		opacity: 1;
		pointer-events: none;
		position: absolute;
		right: 0;
		transition: opacity 120ms ease;
	}
	.tweets-scroll-frame.at-bottom::after,
	.tweets-scroll-frame.no-overflow::after {
		opacity: 0;
	}
	.tweet-pagination {
		align-items: center;
		border-top: 1px solid var(--faint);
		display: flex;
		justify-content: space-between;
		margin-top: 12px;
		padding-top: 10px;
	}
	.tweet-pagination[hidden] {
		display: none;
	}
	.tweet-page-button {
		background: transparent;
		border: 0;
		color: var(--muted);
		cursor: pointer;
		font: inherit;
		height: 28px;
		padding: 0;
		width: 28px;
	}
	.tweet-page-button:hover:not(:disabled) {
		color: var(--accent);
	}
	.tweet-page-button:disabled {
		cursor: default;
		opacity: 0.25;
	}
	.tweet-page-status {
		color: var(--muted);
		font-family: "SFMono-Regular", Consolas, monospace;
		font-size: 11px;
	}
	.tweet-item.is-reply {
		border-top: 0 !important;
		margin-left: 28px;
		padding-left: 18px;
		padding-top: 18px;
	}
	.tweet-item.is-reply::before {
		background: var(--faint);
		content: "";
		height: 30px;
		left: 0;
		position: absolute;
		top: 0;
		width: 1px;
	}
	.tweet-item.is-reply::after {
		background: var(--faint);
		content: "";
		height: 1px;
		left: 0;
		position: absolute;
		top: 29px;
		width: 10px;
	}
	.tweet-item.is-reply.has-external-thread {
		border-top: 1px solid var(--faint) !important;
		padding-top: 28px;
	}
	.tweet-item.is-reply.has-external-thread::before,
	.tweet-item.is-reply.has-external-thread::after {
		display: none;
	}
	.reply-context {
		color: var(--muted);
		font-family: "SFMono-Regular", Consolas, monospace;
		font-size: 11px;
		margin: 0 0 5px;
	}
	.reply-author {
		color: var(--accent);
	}
	.reply-thread {
		display: grid;
		gap: 12px;
		margin: 0 0 16px -46px;
		padding-left: 18px;
		position: relative;
	}
	.reply-thread::before {
		background: var(--faint);
		content: "";
		inset: 10px auto -16px 0;
		position: absolute;
		width: 1px;
	}
	.thread-post {
		display: grid;
		gap: 4px;
		position: relative;
	}
	.thread-post::before {
		background: var(--faint);
		content: "";
		height: 1px;
		left: -18px;
		position: absolute;
		top: 10px;
		width: 10px;
	}
	.thread-post-author {
		color: var(--muted);
		font-family: "SFMono-Regular", Consolas, monospace;
		font-size: 11px;
	}
	.thread-post-text {
		color: var(--muted);
		font-size: 13px;
		margin: 0;
		max-width: 58ch;
	}
	.generating {
		opacity: 0.35;
		font-style: italic;
	}
	.tweet-media {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		margin-top: 8px;
	}
	.tweet-content {
		min-width: 0;
	}
	.tweet-img {
		border: 1px solid #1d1d1d;
		max-height: 240px;
		max-width: 300px;
		object-fit: cover;
	}
	@media (max-width: 600px) {
		.tweets-viewport {
			height: 55vh;
			min-height: 320px;
			padding-right: 6px;
		}
		.tweet-item.is-reply {
			margin-left: 12px;
			padding-left: 14px;
		}
		.reply-thread {
			margin-left: -26px;
		}
	}
</style>

<Layout title="writing | MERULOX" description="Writing by Merulox.">
	<h1>Writing</h1>

	<section class="section writing-section">
		<h2 class="eyebrow" style="display:flex;align-items:center;gap:6px">
			<svg width="11" height="11" viewBox="0 0 1200 1227" fill="currentColor" aria-label="X" style="flex-shrink:0;position:relative;top:0.5px">
				<path d="M714.163 519.284L1160.89 0H1055.03L667.137 450.887L357.328 0H0L468.492 681.821L0 1226.37H105.866L515.491 750.218L842.672 1226.37H1200L714.137 519.284H714.163ZM569.165 687.828L521.697 619.934L144.011 79.6944H306.615L611.412 515.685L658.88 583.579L1055.08 1150.3H892.476L569.165 687.854V687.828Z"/>
			</svg>
			posts
		</h2>
		<div class="tweets-scroll-frame" id="tweets-scroll-frame">
			<div class="tweets-viewport" id="tweets-viewport">
				<div id="tweets-container" data-static-updated-at={tweetData.updatedAt ?? 0}>
					{
						tweets.length > 0 ? (
							tweets.map((tweet, index) => (
								<article
									class:list={[
										"work-item",
										"tweet-item",
										{
											"is-reply": tweet.isReply,
											"has-external-thread": externalReplyThread(tweet).length > 0,
										},
									]}
									data-tweet-index={index}
									hidden={index >= TWEET_PAGE_SIZE}
								>
									{externalReplyThread(tweet).length > 0 && (
										<div class="reply-thread">
											{externalReplyThread(tweet).map((post) => (
												<a class="thread-post" href={post.url} target="_blank" rel="noopener" style="text-decoration:none">
													<span class="thread-post-author">{post.author ?? "original post"}</span>
													<p class="thread-post-text">{post.text}</p>
												</a>
											))}
										</div>
									)}
									<header class="item-header">
										<div class="tweet-content">
											<a href={tweet.url} target="_blank" rel="noopener" style="text-decoration:none">
												{tweet.isReply && (
													<p class="reply-context">
														<span class="reply-author">{tweet.author ?? "@merulox"}</span>
														{tweet.replyTo && <> → {tweet.replyTo}</>}
													</p>
												)}
												<p style="font-size:13px;max-width:58ch;color:var(--text);margin:0">{tweet.text}</p>
											</a>
											{tweet.media && tweet.media.length > 0 && (
												<div class="tweet-media">
													{tweet.media.map((url) => (
														<a href={tweet.url} target="_blank" rel="noopener">
															<img src={url} alt="" loading="lazy" class="tweet-img" />
														</a>
													))}
												</div>
											)}
										</div>
										<time class="date" datetime={tweet.timestamp}>{formatTweetTimestamp(tweet)}</time>
									</header>
								</article>
							))
						) : (
							<p class="muted">Nothing here yet.</p>
						)
					}
				</div>
			</div>
		</div>
		<script id="static-tweets" type="application/json" set:html={JSON.stringify(tweets).replaceAll("<", "\\u003c")} />
		<nav class="tweet-pagination" id="tweet-pagination" aria-label="X post pages" hidden={tweets.length <= TWEET_PAGE_SIZE}>
			<button class="tweet-page-button" id="tweet-prev" type="button" aria-label="Previous X posts" title="Previous page">←</button>
			<span class="tweet-page-status" id="tweet-page-status">1 / {Math.max(1, Math.ceil(tweets.length / TWEET_PAGE_SIZE))}</span>
			<button class="tweet-page-button" id="tweet-next" type="button" aria-label="Next X posts" title="Next page">→</button>
		</nav>
		<a
			class="email"
			href="https://x.com/merulox"
			target="_blank"
			rel="noopener"
			id="x-link">→ x.com/@merulox</a
		>
	</section>

	<section class="section writing-section">
		<h2 class="eyebrow">Substack</h2>
		<div id="posts-container">
			<p class="muted">Loading...</p>
		</div>
		<a
			class="email"
			href="https://substack.com/@merulox"
			target="_blank"
			rel="noopener"
			id="substack-link"
			style="display:none">→ substack.com/@merulox</a
		>
	</section>

	<script>
		// ── Substack ──────────────────────────────────────────────
		const SUBSTACK_API = "/api/feed";

		function formatDate(dateStr: string) {
			if (!dateStr) return "";
			const d = new Date(dateStr);
			return d.toISOString().slice(0, 7);
		}

		function postSlug(url: string) {
			return url.replace(/[^a-z0-9]/gi, "-").slice(-40);
		}

		async function fetchSummary(postUrl: string): Promise<string> {
			const res = await fetch(`/api/summarize?url=${encodeURIComponent(postUrl)}`);
			const data = await res.json();
			return data.summary ?? "";
		}

		function renderSummary(slug: string, text: string) {
			const el = document.getElementById(`summary-${slug}`);
			if (!el) return;
			el.textContent = text;
			el.classList.remove("generating");
		}

		async function loadPosts() {
			const container = document.getElementById("posts-container")!;
			const link = document.getElementById("substack-link") as HTMLAnchorElement;

			try {
				const res = await fetch(SUBSTACK_API);
				const data = await res.json();

				if (data.status !== "ok" || !data.items?.length) {
					container.innerHTML = '<p class="muted">Nothing here yet.</p>';
					link.style.display = "inline";
					return;
				}

				container.innerHTML = data.items
					.map((post: { link: string; title: string; pubDate: string; summary?: string }) => {
						const slug = postSlug(post.link);
						const summaryHtml = `<p id="summary-${slug}" class="muted${post.summary ? "" : " generating"}" style="margin-top:6px;font-size:13px;max-width:58ch">${post.summary ?? "generating…"}</p>`;
						return `
					<article class="work-item">
						<header class="item-header">
							<a href="${post.link}" target="_blank" rel="noopener" style="text-decoration:none">
								<h2 style="font-size:15px;font-weight:600">${post.title}</h2>
							</a>
							<time class="date">${formatDate(post.pubDate)}</time>
						</header>
						${summaryHtml}
					</article>`;
					})
					.join("");

				link.style.display = "inline";

				// Generate only summaries that do not exist in the shared KV store.
				for (const post of data.items as { link: string; summary?: string }[]) {
					if (post.summary) continue;
					fetchSummary(post.link).then((summary) => {
						if (!summary) return;
						renderSummary(postSlug(post.link), summary);
					}).catch(() => {
						renderSummary(postSlug(post.link), "");
					});
				}
			} catch {
				container.innerHTML = '<p class="muted">Unable to load posts.</p>';
				link.style.display = "inline";
			}
		}

		// X pagination
		const TWEET_PAGE_SIZE = 100;
		const LIVE_TWEETS_API = "/api/tweets";
		const LIVE_TWEETS_POLL_MS = 30_000;
		let currentTweetPage = 0;
		let latestTweetUpdate = Number(document.getElementById("tweets-container")?.dataset.staticUpdatedAt ?? 0) * 1000;

		function escapeHtml(value: unknown) {
			return String(value ?? "")
				.replaceAll("&", "&amp;")
				.replaceAll("<", "&lt;")
				.replaceAll(">", "&gt;")
				.replaceAll('"', "&quot;")
				.replaceAll("'", "&#39;");
		}

		function orchestrateLiveTweets(input: any[]) {
			const replies = new Map<string, any[]>();
			const roots: any[] = [];
			const urls = new Set(input.map((tweet) => tweet.url));
			for (const tweet of input) {
				if (tweet.isReply && tweet.replyToUrl && urls.has(tweet.replyToUrl)) {
					replies.set(tweet.replyToUrl, [...(replies.get(tweet.replyToUrl) ?? []), tweet]);
				} else {
					roots.push(tweet);
				}
			}
			const flatten = (tweet: any): any[] => [tweet, ...(replies.get(tweet.url) ?? []).flatMap(flatten)];
			return roots.flatMap(flatten);
		}

		function formatLiveTweetTimestamp(tweet: any) {
			if (!tweet.timestamp) return tweet.date ?? "";
			return new Intl.DateTimeFormat("en-CA", {
				timeZone: "America/Toronto",
				year: "numeric",
				month: "2-digit",
				day: "2-digit",
				hour: "2-digit",
				minute: "2-digit",
				hour12: false,
			}).format(new Date(tweet.timestamp)).replace(",", "");
		}

		function renderLiveTweets(input: any[]) {
			const tweets = orchestrateLiveTweets(input.filter((tweet) => tweet?.text && tweet?.url).slice(0, 300));
			const ownUrls = new Set(tweets.map((tweet) => tweet.url));
			const container = document.getElementById("tweets-container")!;
			container.innerHTML = tweets.map((tweet, index) => {
				const externalThread = (tweet.replyThread ?? []).filter((post: any) => !ownUrls.has(post.url));
				const thread = externalThread.length ? `
					<div class="reply-thread">
						${externalThread.map((post: any) => `
							<a class="thread-post" href="${escapeHtml(post.url)}" target="_blank" rel="noopener" style="text-decoration:none">
								<span class="thread-post-author">${escapeHtml(post.author ?? "original post")}</span>
								<p class="thread-post-text">${escapeHtml(post.text)}</p>
							</a>`).join("")}
					</div>` : "";
				const reply = tweet.isReply ? `
					<p class="reply-context">
						<span class="reply-author">${escapeHtml(tweet.author ?? "@merulox")}</span>
						${tweet.replyTo ? ` → ${escapeHtml(tweet.replyTo)}` : ""}
					</p>` : "";
				const media = Array.isArray(tweet.media) && tweet.media.length ? `
					<div class="tweet-media">
						${tweet.media.map((url: string) => `
							<a href="${escapeHtml(tweet.url)}" target="_blank" rel="noopener">
								<img src="${escapeHtml(url)}" alt="" loading="lazy" class="tweet-img">
							</a>`).join("")}
					</div>` : "";
				return `
					<article class="work-item tweet-item${tweet.isReply ? " is-reply" : ""}${externalThread.length ? " has-external-thread" : ""}" data-tweet-index="${index}">
						${thread}
						<header class="item-header">
							<div class="tweet-content">
								<a href="${escapeHtml(tweet.url)}" target="_blank" rel="noopener" style="text-decoration:none">
									${reply}
									<p style="font-size:13px;max-width:58ch;color:var(--text);margin:0">${escapeHtml(tweet.text)}</p>
								</a>
								${media}
							</div>
							<time class="date" datetime="${escapeHtml(tweet.timestamp ?? "")}">${escapeHtml(formatLiveTweetTimestamp(tweet))}</time>
						</header>
					</article>`;
			}).join("") || '<p class="muted">Nothing here yet.</p>';
			currentTweetPage = 0;
			setupTweetPagination(container);
		}

		async function refreshLiveTweets() {
			try {
				const response = await fetch(LIVE_TWEETS_API, { cache: "no-store" });
				if (!response.ok) return;
				const data = await response.json();
				if (!Array.isArray(data.tweets) || !data.tweets.length || Number(data.updatedAt) <= latestTweetUpdate) return;
				renderLiveTweets(data.tweets);
				latestTweetUpdate = Number(data.updatedAt);
			} catch {
				// Keep the deployed static list as the offline/error fallback.
			}
		}

		function setupTweetPagination(container: HTMLElement) {
			const items = Array.from(container.querySelectorAll<HTMLElement>(".tweet-item"));
			const pageCount = Math.max(1, Math.ceil(items.length / TWEET_PAGE_SIZE));
			currentTweetPage = Math.min(currentTweetPage, pageCount - 1);

			for (const [index, item] of items.entries()) {
				item.hidden = Math.floor(index / TWEET_PAGE_SIZE) !== currentTweetPage;
			}

			const pagination = document.getElementById("tweet-pagination")!;
			const previous = document.getElementById("tweet-prev") as HTMLButtonElement;
			const next = document.getElementById("tweet-next") as HTMLButtonElement;
			const status = document.getElementById("tweet-page-status")!;

			pagination.hidden = pageCount <= 1;
			previous.disabled = currentTweetPage === 0;
			next.disabled = currentTweetPage >= pageCount - 1;
			status.textContent = `${currentTweetPage + 1} / ${pageCount}`;
			document.getElementById("tweets-viewport")?.scrollTo({ top: 0 });
			requestAnimationFrame(updateTweetScrollHint);
		}

		function updateTweetScrollHint() {
			const viewport = document.getElementById("tweets-viewport")!;
			const frame = document.getElementById("tweets-scroll-frame")!;
			const remaining = viewport.scrollHeight - viewport.clientHeight - viewport.scrollTop;
			frame.classList.toggle("no-overflow", viewport.scrollHeight <= viewport.clientHeight + 1);
			frame.classList.toggle("at-bottom", remaining <= 2);
		}

		loadPosts();
		setupTweetPagination(document.getElementById("tweets-container")!);
		refreshLiveTweets();
		window.setInterval(refreshLiveTweets, LIVE_TWEETS_POLL_MS);

		document.getElementById("tweet-prev")?.addEventListener("click", () => {
			currentTweetPage -= 1;
			setupTweetPagination(document.getElementById("tweets-container")!);
		});
		document.getElementById("tweet-next")?.addEventListener("click", () => {
			currentTweetPage += 1;
			setupTweetPagination(document.getElementById("tweets-container")!);
		});
		document.getElementById("tweets-viewport")?.addEventListener("scroll", updateTweetScrollHint, { passive: true });
		window.addEventListener("resize", updateTweetScrollHint);
		</script>
</Layout>
