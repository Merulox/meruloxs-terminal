---
import Layout from "../../layouts/Layout.astro";
import { projects } from "../../data/projects";
---

<Layout
	title="projects | MERULOX"
	description="Projects built by Merulox."
>
	<h1>Projects</h1>

	<div class="proj-list">
		{
			projects.map((p, i) => (
				<article class={`proj${i === 0 ? " open" : ""}`}>
					<button class="proj-head list-item" aria-expanded={i === 0 ? "true" : "false"}>
						<span class="proj-caret" aria-hidden="true">›</span>
						<span class="proj-name">{p.name}</span>
						<span class={`proj-state ${p.state}`}>{p.state}</span>
						<span class="proj-date">{p.date}</span>
					</button>
					<div class="proj-body">
						<p>{p.description}</p>
						{
							p.github && (
								<a class="project-repo" href={p.github} target="_blank" rel="noreferrer">
									GitHub ↗
								</a>
							)
						}
						<ul class="tag-list">
							{p.tags.map((tag) => (
								<li>{tag}</li>
							))}
						</ul>
					</div>
				</article>
			))
		}
	</div>

	<script>
		document.querySelectorAll<HTMLButtonElement>(".proj-head").forEach((head) => {
			head.addEventListener("click", () => {
				const project = head.closest(".proj")!;
				const open = project.classList.toggle("open");
				head.setAttribute("aria-expanded", open ? "true" : "false");
			});
		});
	</script>
</Layout>
