---
import Layout from "../layouts/Layout.astro";
import paths from "../data/books.json";
import goodreads from "../data/goodreads.json";

type Book = { title: string; author: string; stars: number; read?: boolean; note: string };
type Path = { path: string; desc: string; books: Book[] };
type GoodreadsBook = {
	id?: string;
	title: string;
	author: string;
	url: string;
	image?: string;
	rating?: number;
	averageRating?: string;
	readAt?: string;
	addedAt?: string;
	updatedAt?: string;
	published?: string;
	pages?: number | null;
	shelves?: string[];
};

const data = paths as Path[];
const liveShelves = goodreads.shelves as Record<string, GoodreadsBook[]>;
const shelfStack = [
	{ key: "favorites", label: "Favorites", empty: "No favorites marked.", books: liveShelves.favorites ?? [] },
	{ key: "reading", label: "Reading", empty: "No active reads.", books: liveShelves.reading ?? [] },
	{ key: "completed", label: "Completed", empty: "No completed books yet.", books: liveShelves.completed ?? [] },
	{ key: "dropped", label: "Dropped", empty: "No dropped books.", books: liveShelves.dropped ?? [] },
	{ key: "planToRead", label: "Plan to read", empty: "No plan-to-read entries.", books: liveShelves.planToRead ?? [] },
];
const hasLiveShelves = shelfStack.some((stack) => stack.books.length > 0);
const liveBookCount = shelfStack.reduce((count, stack) => count + stack.books.length, 0);
const liveSource = goodreads.source === "goodreads" ? "Goodreads" : "reading";
const liveGeneratedAt = typeof goodreads.generatedAt === "string" ? goodreads.generatedAt : "";
const liveSyncDate = liveGeneratedAt ? new Date(liveGeneratedAt) : null;
const liveSyncLabel = liveSyncDate && !Number.isNaN(liveSyncDate.getTime())
	? liveSyncDate.toLocaleDateString("en-US", { month: "short", day: "2-digit", year: "numeric" })
	: "";

const totalBooks = new Set(data.flatMap((path) => path.books.map((book) => book.title))).size;
const read = new Set(data.flatMap((path) => path.books.filter((book) => book.read).map((book) => book.title))).size;
const levels = [
	{ stars: 1, name: "foundation" },
	{ stars: 2, name: "models" },
	{ stars: 3, name: "mastery" },
	{ stars: 4, name: "frontiers" },
];

function formatDate(value?: string): string {
	if (!value) return "";
	const date = new Date(`${value}T00:00:00`);
	if (Number.isNaN(date.getTime())) return value;
	return date.toLocaleDateString("en-US", { month: "short", day: "2-digit", year: "numeric" });
}

function bookMeta(book: GoodreadsBook, shelfKey: string): string {
	if (shelfKey === "completed" && book.readAt) return `read ${formatDate(book.readAt)}`;
	if (shelfKey === "planToRead" && book.addedAt) return `added ${formatDate(book.addedAt)}`;
	if (shelfKey === "reading" && book.updatedAt) return `updated ${formatDate(book.updatedAt)}`;
	if (book.readAt) return `read ${formatDate(book.readAt)}`;
	if (book.updatedAt) return formatDate(book.updatedAt);
	if (book.addedAt) return formatDate(book.addedAt);
	return "";
}

function ratingLabel(rating?: number): string {
	return rating && rating > 0 ? "★".repeat(rating) : "";
}
---

<style>
	.path-index {
		display: flex;
		flex-wrap: wrap;
		gap: 8px 18px;
		margin: 18px 0 38px;
	}
	.path-index a {
		color: var(--muted);
		font-family: "SFMono-Regular", Consolas, monospace;
		font-size: 11px;
		text-decoration: none;
	}
	.path-index a:hover {
		color: var(--accent);
	}
	.reading-paths {
		border-bottom: 1px solid var(--line);
	}
	.reading-path {
		border-top: 1px solid var(--line);
		scroll-margin-top: 24px;
	}
	.path-summary {
		align-items: baseline;
		cursor: pointer;
		display: grid;
		gap: 12px;
		grid-template-columns: 20px minmax(0, 1fr) auto;
		list-style: none;
		margin: 0 -8px;
		padding: 18px 8px;
	}
	.path-summary::-webkit-details-marker {
		display: none;
	}
	.path-marker {
		color: var(--accent);
		font-family: "SFMono-Regular", Consolas, monospace;
		font-size: 11px;
	}
	.reading-path[open] .path-marker::before {
		content: "−";
	}
	.reading-path:not([open]) .path-marker::before {
		content: "+";
	}
	.path-name {
		color: var(--text);
		font-size: 14px;
		font-weight: 600;
	}
	.path-count {
		color: var(--muted);
		font-family: "SFMono-Regular", Consolas, monospace;
		font-size: 11px;
		white-space: nowrap;
	}
	.path-body {
		padding: 0 0 34px 32px;
	}
	.path-desc {
		color: var(--muted);
		font-size: 12px;
		margin: -4px 0 24px;
		max-width: 58ch;
	}
	.path-level + .path-level {
		margin-top: 28px;
	}
	.path-level .book-line {
		grid-template-columns: minmax(0, 1fr) auto;
	}
	.level-head {
		align-items: baseline;
		display: flex;
		gap: 10px;
		margin-bottom: 14px;
	}
	.level-stars {
		color: var(--accent);
		font-size: 10px;
		letter-spacing: 1px;
	}
	.level-name {
		color: var(--muted);
		font-family: "SFMono-Regular", Consolas, monospace;
		font-size: 10px;
		text-transform: uppercase;
	}
	.path-summary:focus-visible {
		box-shadow: inset 0 0 0 1px var(--accent);
		outline: 0;
	}
	.goodreads-link {
		margin: 22px 0 34px;
	}
	.goodreads-link .email {
		margin-top: 0;
	}
	.live-shelf-stack {
		display: grid;
		gap: 28px;
		margin-bottom: 56px;
	}
	.live-shelf-section {
		border-top: 1px solid var(--line);
	}
	.live-shelf-section summary {
		cursor: pointer;
		list-style: none;
	}
	.live-shelf-section summary::-webkit-details-marker {
		display: none;
	}
	.live-shelf-heading {
		align-items: baseline;
		display: grid;
		grid-template-columns: 16px minmax(0, 1fr) auto;
		justify-content: space-between;
		gap: 10px;
		margin: 0 -8px 14px;
		padding: 12px 8px;
	}
	.live-shelf-heading .shelf-head {
		margin-bottom: 0;
	}
	.live-shelf-heading:focus-visible {
		box-shadow: inset 0 0 0 1px var(--accent);
		outline: 0;
	}
	.live-shelf-marker {
		color: var(--accent);
		font-family: "SFMono-Regular", Consolas, monospace;
		font-size: 11px;
	}
	.live-shelf-section[open] .live-shelf-marker::before {
		content: "−";
	}
	.live-shelf-section:not([open]) .live-shelf-marker::before {
		content: "+";
	}
	.live-shelf-section:not([open]) .live-shelf-heading {
		margin-bottom: 0;
	}
	.live-book-list {
		display: grid;
		gap: 10px;
		list-style: none;
		max-height: 282px;
		overflow-y: auto;
		padding: 0;
		scrollbar-width: none;
		-webkit-mask-image: linear-gradient(to bottom, #000 calc(100% - 28px), transparent 100%);
		mask-image: linear-gradient(to bottom, #000 calc(100% - 28px), transparent 100%);
	}
	.live-book-list::-webkit-scrollbar {
		display: none;
	}
	.live-book {
		display: grid;
		grid-template-columns: 42px minmax(0, 1fr);
		gap: 12px;
		min-width: 0;
	}
	.live-book-cover,
	.live-book-cover-fallback {
		aspect-ratio: 2 / 3;
		background: var(--line);
		display: block;
		width: 42px;
	}
	.live-book-cover {
		object-fit: cover;
	}
	.live-book-cover-fallback {
		border: 1px solid var(--line);
	}
	.live-book-copy {
		min-width: 0;
		padding-top: 1px;
	}
	.live-book-line {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 12px;
		align-items: baseline;
	}
	.live-book-title {
		color: var(--text);
		font-size: 14px;
		font-weight: 600;
		line-height: 1.35;
		text-decoration: none;
	}
	.live-book-title:hover {
		color: var(--accent);
	}
	.live-book-date {
		color: var(--muted);
		font-family: "SFMono-Regular", Consolas, monospace;
		font-size: 10px;
		white-space: nowrap;
	}
	.live-book-subline {
		align-items: baseline;
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		margin-top: 2px;
	}
	.live-book-author,
	.live-book-pages,
	.live-book-average {
		color: var(--muted);
		font-size: 12px;
	}
	.live-book-rating {
		color: var(--accent);
		font-size: 10px;
		letter-spacing: 1px;
	}
	.live-book-pages::before,
	.live-book-average::before {
		color: var(--faint);
		content: "·";
		margin-right: 6px;
	}
	.live-shelf-empty {
		color: var(--muted);
		font-size: 12px;
	}
	.live-shelf-meta {
		color: var(--muted);
		font-family: "SFMono-Regular", Consolas, monospace;
		font-size: 10px;
		margin: -8px 0 20px;
	}
	@media (max-width: 600px) {
		.path-body {
			padding-left: 20px;
		}
		.path-summary {
			grid-template-columns: 16px minmax(0, 1fr) auto;
		}
		.live-book-line {
			grid-template-columns: minmax(0, 1fr);
			gap: 2px;
		}
		.live-book-date {
			white-space: normal;
		}
	}
</style>

<Layout title="reading | MERULOX" description="What merulox reads — what shaped me, and the curriculum.">
	<div class="page-head">
		<h1>Reading</h1>
		<span class="date">notes and a map</span>
	</div>

	<p class="reading-intro">
		The first shelf is history: books that already shaped how I think. The
		curriculum below is a set of paths I have not read through yet. Within each
		path, stars mark progression: foundation, models, mastery, then frontiers.
		</p>

	{
		hasLiveShelves && (
			<section class="shelf-section">
				<div class="shelf-head-row">
					<h2 class="shelf-head">Live shelf</h2>
					<span class="date">{liveBookCount} recent</span>
				</div>
				{liveSyncLabel && <p class="live-shelf-meta">synced from {liveSource.toLowerCase()} · {liveSyncLabel}</p>}
				<div class="live-shelf-stack">
					{shelfStack.map((stack) => (
						<details class="live-shelf-section" data-shelf={stack.key} {...(stack.key === "reading" ? { open: true } : {})}>
							<summary class="live-shelf-heading">
								<span class="live-shelf-marker" aria-hidden="true"></span>
								<h3 class="shelf-head">{stack.label}</h3>
								<span class="date">{stack.books.length}</span>
							</summary>
							{stack.books.length > 0 ? (
								<ul class="live-book-list">
									{stack.books.map((book) => (
										<li class="live-book">
											{book.image ? (
												<img class="live-book-cover" src={book.image} alt="" loading="lazy" />
											) : (
												<span class="live-book-cover-fallback" aria-hidden="true"></span>
											)}
											<div class="live-book-copy">
												<div class="live-book-line">
													<a class="live-book-title" href={book.url} target="_blank" rel="noopener">
														{book.title}
													</a>
													<span class="live-book-date">{bookMeta(book, stack.key)}</span>
												</div>
												<div class="live-book-subline">
													<span class="live-book-author">{book.author}</span>
													{ratingLabel(book.rating) && (
														<span class="live-book-rating" aria-label={`${book.rating} of 5`}>
															{ratingLabel(book.rating)}
														</span>
													)}
													{book.pages && <span class="live-book-pages">{book.pages}p</span>}
													{book.averageRating && <span class="live-book-average">avg {book.averageRating}</span>}
												</div>
											</div>
										</li>
									))}
								</ul>
							) : (
								<p class="live-shelf-empty">{stack.empty}</p>
							)}
						</details>
					))}
				</div>
			</section>
		)
	}

	<p class="goodreads-link">
		<a
			class="email"
			href="https://www.goodreads.com/user/show/158374147-merulox"
			target="_blank"
			rel="noopener"
		>
			→ goodreads.com/merulox
		</a>
	</p>

	<section class="shelf-section">
		<div class="shelf-head-row">
			<h2 class="shelf-head">Paths</h2>
			<span class="date">{read}/{totalBooks} read</span>
		</div>
		<nav class="path-index" aria-label="Reading paths">
			{data.map((path, index) => (
				<a href={`#path-${index + 1}`} data-path-link={index}>
					{String(index + 1).padStart(2, "0")}{" "}{path.path.toLowerCase()}
				</a>
			))}
		</nav>

		<div class="reading-paths">
			{data.map((path, index) => (
				<details class="reading-path" id={`path-${index + 1}`}>
					<summary class="path-summary">
						<span class="path-marker" aria-hidden="true"></span>
						<span class="path-name">{path.path}</span>
						<span class="path-count">{path.books.filter((b) => b.read).length}/{path.books.length}</span>
					</summary>
					<div class="path-body">
						<p class="path-desc">{path.desc}</p>
						{levels.map((level) => {
							const books = path.books.filter((book) => book.stars === level.stars);
							if (!books.length) return null;
							return (
								<section class="path-level">
									<div class="level-head">
										<span class="level-stars">{"★".repeat(level.stars)}</span>
										<span class="level-name">{level.name}</span>
									</div>
									<ul class="book-list">
										{books.map((book) => (
											<li class="book">
												<div class="book-line">
													<span class="book-title">{book.title}</span>
													<span class="book-author">{book.author}</span>
													{book.read && <span class="book-state read">read</span>}
												</div>
												{book.note && <p class="book-note">{book.note}</p>}
											</li>
										))}
									</ul>
								</section>
							);
						})}
					</div>
				</details>
			))}
		</div>
	</section>

	<script>
			const summaries = Array.from(document.querySelectorAll<HTMLElement>(".live-shelf-heading, .path-summary"));
			const details = summaries.map((summary) => summary.closest("details")!);
			const pathSummaries = Array.from(document.querySelectorAll<HTMLElement>(".path-summary"));
			const pathDetails = pathSummaries.map((summary) => summary.closest("details")!);
			const headerItems = Array.from(document.querySelectorAll<HTMLElement>(".site-name, .site-nav a"));

			function isPathSummary(summary: HTMLElement): boolean {
				return summary.classList.contains("path-summary");
			}

			function focusItem(index: number) {
				const target = summaries[(index + summaries.length) % summaries.length];
				target.focus();
				if (target.closest("details")?.open) {
					requestAnimationFrame(() => revealItemContext(index));
				} else {
					target.scrollIntoView({ block: "nearest" });
				}
			}

			function revealItemContext(index: number) {
				const first = details[Math.max(0, index - 2)];
				const last = details[Math.min(details.length - 1, index + 2)];
				const top = window.scrollY + first.getBoundingClientRect().top;
				const bottom = window.scrollY + last.getBoundingClientRect().bottom;
				const margin = 24;
				const available = window.innerHeight - margin * 2;
				const height = bottom - top;
				const target = height <= available
					? top - margin - (available - height) / 2
					: top - margin;

				window.scrollTo({ top: Math.max(0, target), behavior: "smooth" });
			}

			function focusHeader() {
				const target =
					headerItems.find((item) => item.getAttribute("aria-current") === "page") ??
					headerItems[0];
				if (!target) return;
				window.scrollTo({ top: 0, behavior: "smooth" });
				target.focus({ preventScroll: true });
			}

			function closeOtherPaths(targetDetails: HTMLDetailsElement) {
				for (const detail of pathDetails) {
					if (detail !== targetDetails) detail.open = false;
				}
			}

			function openItem(index: number) {
				const targetSummary = summaries[index];
				const targetDetails = details[index];
				if (isPathSummary(targetSummary)) closeOtherPaths(targetDetails);
				targetDetails.open = true;
				requestAnimationFrame(() => requestAnimationFrame(() => revealItemContext(index)));
			}

			pathDetails.forEach((details, index) => {
				details.addEventListener("toggle", () => {
					if (!details.open) return;
					closeOtherPaths(details);
					const summaryIndex = summaries.indexOf(pathSummaries[index]);
					if (summaryIndex >= 0) requestAnimationFrame(() => revealItemContext(summaryIndex));
				});
			});

			document.querySelectorAll<HTMLElement>("[data-path-link]").forEach((link) => {
				link.addEventListener("click", () => {
					const index = Number(link.dataset.pathLink);
					const summaryIndex = summaries.indexOf(pathSummaries[index]);
					if (summaryIndex < 0) return;
					openItem(summaryIndex);
					requestAnimationFrame(() => focusItem(summaryIndex));
				});
			});

		document.addEventListener("keydown", (event) => {
			if (event.ctrlKey || event.metaKey || event.altKey) return;
			const active = document.activeElement as HTMLElement;
			const current = summaries.indexOf(active);
			const isNavKey = ["j", "k", "h", "l", "ArrowDown", "ArrowUp", "ArrowLeft", "ArrowRight", "Enter", " "].includes(event.key);
			if (current < 0 && !isNavKey) return;

			if (event.key === "j" || event.key === "ArrowDown") {
				event.preventDefault();
				event.stopImmediatePropagation();
				focusItem(current < 0 ? 0 : current + 1);
			} else if (event.key === "k" || event.key === "ArrowUp") {
				event.preventDefault();
				event.stopImmediatePropagation();
				if (current <= 0) focusHeader();
				else focusItem(current - 1);
			} else if ((event.key === "l" || event.key === "ArrowRight") && current >= 0) {
				event.preventDefault();
				event.stopImmediatePropagation();
				openItem(current);
			} else if ((event.key === "h" || event.key === "ArrowLeft") && current >= 0) {
				event.preventDefault();
				event.stopImmediatePropagation();
				const activeDetails = active.closest("details")!;
				if (activeDetails.open) activeDetails.open = false;
				else if (current === 0) focusHeader();
			} else if ((event.key === "Enter" || event.key === " ") && current >= 0) {
				event.preventDefault();
				event.stopImmediatePropagation();
				const details = active.closest("details")!;
				if (details.open) details.open = false;
				else openItem(current);
			}
		}, true);
	</script>
</Layout>
