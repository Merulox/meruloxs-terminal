---
import Layout from "../layouts/Layout.astro";
import paths from "../data/books.json";
import shelf from "../data/reading.json";

type Book = { title: string; author: string; stars: number; read?: boolean; note: string };
type Path = { path: string; desc: string; books: Book[] };
type Shaped = { title: string; author: string; stars: number; note: string };
type Recent = { title: string; author: string; note: string };

const data = paths as Path[];
const shaped = (shelf.shaped ?? []) as Shaped[];
const recent = (shelf.recent ?? []) as Recent[];

const totalBooks = data.reduce((n, path) => n + path.books.length, 0);
const read = data.reduce((n, path) => n + path.books.filter((b) => b.read).length, 0);
const levels = [
	{ stars: 1, name: "entry" },
	{ stars: 2, name: "core" },
	{ stars: 3, name: "advanced" },
];
---

<style>
	.path-index {
		display: flex;
		flex-wrap: wrap;
		gap: 8px 18px;
		margin: 18px 0 38px;
	}
	.path-index a {
		color: var(--muted);
		font-family: "SFMono-Regular", Consolas, monospace;
		font-size: 11px;
		text-decoration: none;
	}
	.path-index a:hover {
		color: var(--accent);
	}
	.reading-paths {
		border-bottom: 1px solid var(--line);
	}
	.reading-path {
		border-top: 1px solid var(--line);
		scroll-margin-top: 24px;
	}
	.path-summary {
		align-items: baseline;
		cursor: pointer;
		display: grid;
		gap: 12px;
		grid-template-columns: 20px minmax(0, 1fr) auto;
		list-style: none;
		margin: 0 -8px;
		padding: 18px 8px;
	}
	.path-summary::-webkit-details-marker {
		display: none;
	}
	.path-marker {
		color: var(--accent);
		font-family: "SFMono-Regular", Consolas, monospace;
		font-size: 11px;
	}
	.reading-path[open] .path-marker::before {
		content: "−";
	}
	.reading-path:not([open]) .path-marker::before {
		content: "+";
	}
	.path-name {
		color: var(--text);
		font-size: 14px;
		font-weight: 600;
	}
	.path-count {
		color: var(--muted);
		font-family: "SFMono-Regular", Consolas, monospace;
		font-size: 11px;
		white-space: nowrap;
	}
	.path-body {
		padding: 0 0 34px 32px;
	}
	.path-desc {
		color: var(--muted);
		font-size: 12px;
		margin: -4px 0 24px;
		max-width: 58ch;
	}
	.path-level + .path-level {
		margin-top: 28px;
	}
	.path-level .book-line {
		grid-template-columns: minmax(0, 1fr) auto;
	}
	.level-head {
		align-items: baseline;
		display: flex;
		gap: 10px;
		margin-bottom: 14px;
	}
	.level-stars {
		color: var(--accent);
		font-size: 10px;
		letter-spacing: 1px;
	}
	.level-name {
		color: var(--muted);
		font-family: "SFMono-Regular", Consolas, monospace;
		font-size: 10px;
		text-transform: uppercase;
	}
	.path-summary:focus-visible {
		box-shadow: inset 0 0 0 1px var(--accent);
		outline: 0;
	}
	.goodreads-link {
		margin: 22px 0 34px;
	}
	.goodreads-link .email {
		margin-top: 0;
	}
	@media (max-width: 600px) {
		.path-body {
			padding-left: 20px;
		}
		.path-summary {
			grid-template-columns: 16px minmax(0, 1fr) auto;
		}
	}
</style>

<Layout title="reading | MERULOX" description="What merulox reads — what shaped me, and the curriculum.">
	<div class="page-head">
		<h1>Reading</h1>
		<span class="date">notes and a map</span>
	</div>

	<p class="reading-intro">
		The first shelf is history: books that already shaped how I think. The
		curriculum below is a set of paths I have not read through yet. Within each
		path, stars indicate progression: entry, core, then advanced.
		</p>

		<p class="goodreads-link">
			<a
				class="email"
				href="https://www.goodreads.com/user/show/158374147-merulox"
				target="_blank"
				rel="noopener"
			>
				→ goodreads.com/merulox
			</a>
		</p>

	{
		shaped.length > 0 && (
			<section class="shelf-section">
				<h2 class="shelf-head">Shaped me</h2>
				<ul class="book-list">
					{shaped.map((b) => (
						<li class="book">
							<div class="book-line">
								<span class="book-stars" aria-label={`${b.stars} of 5`}>
									{"★".repeat(b.stars)}
									<span class="book-stars-empty">{"★".repeat(Math.max(0, 5 - b.stars))}</span>
								</span>
								<span class="book-title">{b.title}</span>
								<span class="book-author">{b.author}</span>
							</div>
							{b.note && <p class="book-note">{b.note}</p>}
						</li>
					))}
				</ul>
			</section>
		)
	}

	{
		recent.length > 0 && (
			<section class="shelf-section">
				<h2 class="shelf-head">Recently finished</h2>
				<ul class="book-list">
					{recent.map((b) => (
						<li class="book">
							<div class="book-line">
								<span class="book-stars book-check" aria-hidden="true">✓</span>
								<span class="book-title">{b.title}</span>
								<span class="book-author">{b.author}</span>
							</div>
							{b.note && <p class="book-note">{b.note}</p>}
						</li>
					))}
				</ul>
			</section>
		)
	}

	<section class="shelf-section">
		<div class="shelf-head-row">
			<h2 class="shelf-head">Paths</h2>
			<span class="date">{read}/{totalBooks} read</span>
		</div>
		<nav class="path-index" aria-label="Reading paths">
			{data.map((path, index) => (
				<a href={`#path-${index + 1}`} data-path-link={index}>
					{String(index + 1).padStart(2, "0")}{" "}{path.path.toLowerCase()}
				</a>
			))}
		</nav>

		<div class="reading-paths">
			{data.map((path, index) => (
				<details class="reading-path" id={`path-${index + 1}`}>
					<summary class="path-summary">
						<span class="path-marker" aria-hidden="true"></span>
						<span class="path-name">{path.path}</span>
						<span class="path-count">{path.books.filter((b) => b.read).length}/{path.books.length}</span>
					</summary>
					<div class="path-body">
						<p class="path-desc">{path.desc}</p>
						{levels.map((level) => {
							const books = path.books.filter((book) => book.stars === level.stars);
							if (!books.length) return null;
							return (
								<section class="path-level">
									<div class="level-head">
										<span class="level-stars">{"★".repeat(level.stars)}</span>
										<span class="level-name">{level.name}</span>
									</div>
									<ul class="book-list">
										{books.map((book) => (
											<li class="book">
												<div class="book-line">
													<span class="book-title">{book.title}</span>
													<span class="book-author">{book.author}</span>
													{book.read && <span class="book-state read">read</span>}
												</div>
												{book.note && <p class="book-note">{book.note}</p>}
											</li>
										))}
									</ul>
								</section>
							);
						})}
					</div>
				</details>
			))}
		</div>
	</section>

		<script>
			const summaries = Array.from(document.querySelectorAll<HTMLElement>(".path-summary"));
			const pathDetails = summaries.map((summary) => summary.closest("details")!);

			function focusPath(index: number) {
				const target = summaries[(index + summaries.length) % summaries.length];
				target.focus();
				if (target.closest("details")?.open) {
					requestAnimationFrame(() => revealPathContext(index));
				} else {
					target.scrollIntoView({ block: "nearest" });
				}
			}

			function revealPathContext(index: number) {
				const first = pathDetails[Math.max(0, index - 2)];
				const last = pathDetails[Math.min(pathDetails.length - 1, index + 2)];
				const top = window.scrollY + first.getBoundingClientRect().top;
				const bottom = window.scrollY + last.getBoundingClientRect().bottom;
				const margin = 24;
				const available = window.innerHeight - margin * 2;
				const height = bottom - top;
				const target = height <= available
					? top - margin - (available - height) / 2
					: top - margin;

				window.scrollTo({ top: Math.max(0, target), behavior: "smooth" });
			}

			function openPath(index: number) {
				for (const [pathIndex, details] of pathDetails.entries()) {
					if (pathIndex !== index) details.open = false;
				}
				pathDetails[index].open = true;
				requestAnimationFrame(() => requestAnimationFrame(() => revealPathContext(index)));
			}

			pathDetails.forEach((details, index) => {
				details.addEventListener("toggle", () => {
					if (details.open) openPath(index);
				});
			});

			document.querySelectorAll<HTMLElement>("[data-path-link]").forEach((link) => {
				link.addEventListener("click", () => {
					const index = Number(link.dataset.pathLink);
					openPath(index);
					requestAnimationFrame(() => focusPath(index));
				});
			});

		document.addEventListener("keydown", (event) => {
			if (event.ctrlKey || event.metaKey || event.altKey) return;
			const active = document.activeElement as HTMLElement;
			const current = summaries.indexOf(active);
			const isPathKey = ["j", "k", "h", "l", "ArrowDown", "ArrowUp", "ArrowLeft", "ArrowRight", "Enter", " "].includes(event.key);
			if (current < 0 && !isPathKey) return;

			if (event.key === "j" || event.key === "ArrowDown") {
				event.preventDefault();
				event.stopImmediatePropagation();
				focusPath(current < 0 ? 0 : current + 1);
			} else if (event.key === "k" || event.key === "ArrowUp") {
				event.preventDefault();
				event.stopImmediatePropagation();
				focusPath(current < 0 ? summaries.length - 1 : current - 1);
			} else if ((event.key === "l" || event.key === "ArrowRight") && current >= 0) {
				event.preventDefault();
				event.stopImmediatePropagation();
				openPath(current);
			} else if ((event.key === "h" || event.key === "ArrowLeft") && current >= 0) {
				event.preventDefault();
				event.stopImmediatePropagation();
				active.closest("details")!.open = false;
			} else if ((event.key === "Enter" || event.key === " ") && current >= 0) {
				event.preventDefault();
				event.stopImmediatePropagation();
				const details = active.closest("details")!;
				if (details.open) details.open = false;
				else openPath(current);
			}
		}, true);
	</script>
</Layout>
