---
import Layout from "../layouts/Layout.astro";
import tiers from "../data/books.json";
import shelf from "../data/reading.json";

type Book = { title: string; author: string; stars: number; owned: boolean; read?: boolean; note: string };
type Tier = { tier: string; desc: string; books: Book[] };
type Shaped = { title: string; author: string; stars: number; note: string };
type Recent = { title: string; author: string; note: string };

const data = tiers as Tier[];
const shaped = (shelf.shaped ?? []) as Shaped[];
const recent = (shelf.recent ?? []) as Recent[];

const totalBooks = data.reduce((n, t) => n + t.books.length, 0);
const read = data.reduce((n, t) => n + t.books.filter((b) => b.read).length, 0);

// Split the tier label like "TIER 2 — CORE" into a short label + name
function splitTier(label: string): { tag: string; name: string } {
	const parts = label.split("—");
	if (parts.length === 2) return { tag: parts[0].trim(), name: parts[1].trim() };
	return { tag: "", name: label.trim() };
}
---

<Layout title="reading | MERULOX" description="What merulox reads — what shaped me, and the curriculum.">
	<div class="page-head">
		<h1>Reading</h1>
		<span class="date">notes and a map</span>
	</div>

	<p class="reading-intro">
		The first shelf is history: books that already shaped how I think. The
		curriculum below is different. I have not read through it yet; it is a map I
		built for myself, ordered by what should make the next thing easier to read.
	</p>

	{
		shaped.length > 0 && (
			<section class="shelf-section">
				<h2 class="shelf-head">Shaped me</h2>
				<ul class="book-list">
					{shaped.map((b) => (
						<li class="book">
							<div class="book-line">
								<span class="book-stars" aria-label={`${b.stars} of 3`}>
									{"★".repeat(b.stars)}
									<span class="book-stars-empty">{"★".repeat(Math.max(0, 3 - b.stars))}</span>
								</span>
								<span class="book-title">{b.title}</span>
								<span class="book-author">{b.author}</span>
							</div>
							{b.note && <p class="book-note">{b.note}</p>}
						</li>
					))}
				</ul>
			</section>
		)
	}

	{
		recent.length > 0 && (
			<section class="shelf-section">
				<h2 class="shelf-head">Recently finished</h2>
				<ul class="book-list">
					{recent.map((b) => (
						<li class="book">
							<div class="book-line">
								<span class="book-stars book-check" aria-hidden="true">✓</span>
								<span class="book-title">{b.title}</span>
								<span class="book-author">{b.author}</span>
							</div>
							{b.note && <p class="book-note">{b.note}</p>}
						</li>
					))}
				</ul>
			</section>
		)
	}

	<section class="shelf-section">
		<div class="shelf-head-row">
			<h2 class="shelf-head">The curriculum</h2>
			<span class="date">{read}/{totalBooks} read</span>
		</div>
		<p class="reading-intro curriculum-intro">
			A skill tree, not a flex. Each tier assumes the one before it. The point is
			sequence: foundation books first, synthesizers last.
		</p>

		{
			data.map((tier) => {
				const { tag, name } = splitTier(tier.tier);
				return (
					<section class="tier">
						<div class="tier-head">
							<span class="tier-tag">{tag}</span>
							<h3 class="tier-name">{name}</h3>
						</div>
						<p class="tier-desc">{tier.desc}</p>
						<ul class="book-list">
							{tier.books.map((b) => (
								<li class="book">
									<div class="book-line">
										<span class="book-stars" aria-label={`${b.stars} of 3`}>
											{"★".repeat(b.stars)}
											<span class="book-stars-empty">{"★".repeat(Math.max(0, 3 - b.stars))}</span>
										</span>
										<span class="book-title">{b.title}</span>
										<span class="book-author">{b.author}</span>
										{b.read && <span class="book-state read">read</span>}
									</div>
									{b.note && <p class="book-note">{b.note}</p>}
								</li>
							))}
						</ul>
					</section>
				);
			})
		}
	</section>

	<a
		class="email"
		href="https://www.goodreads.com/user/show/158374147-merulox"
		target="_blank"
		rel="noopener"
	>
		→ goodreads.com/merulox
	</a>
</Layout>
