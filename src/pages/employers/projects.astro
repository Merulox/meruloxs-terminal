---
import Layout from "../../layouts/Layout.astro";
import { employerNavItems } from "../../data/employerNav";

const projects = [
	{
		name: "Boréal Numérique",
		state: "paused",
		date: "2026-04",
		description:
			"AI automation system for Quebec tradespeople: missed-call text-back, lead triage, quote follow-up, and AI-assisted reply and close agents.",
		role: "End-to-end build: Twilio SMS pipeline, Claude reply logic, lead flow, outreach system, and operational testing.",
		impact: "1000+ SMS sent through the system.",
		proof: ["Case study available on request", "Architecture diagram coming soon"],
		tags: ["Twilio", "Claude API", "Python", "n8n"],
	},
	{
		name: "SYNTRA",
		state: "active",
		date: "ongoing",
		description:
			"AI-assisted product discovery pipeline that scrapes and clusters market signals, validates product ideas against those signals, and outputs ranked build-ready briefs.",
		role: "Designed and built the full pipeline.",
		impact:
			"Compresses early product research into structured product opportunities.",
		proof: ["Private walkthrough available", "Architecture diagram coming soon"],
		tags: ["Claude API", "Python", "n8n", "NocoDB"],
	},
	{
		name: "Personal AI Infrastructure",
		state: "active",
		date: "ongoing",
		description:
			"Persistent multi-agent infrastructure for ingesting articles and transcripts, extracting claims, maintaining shared memory, and coordinating specialized agents across long-running work sessions.",
		role: "Sole architect and operator. Built 50+ scripts and services around ingestion, memory, coordination, and task execution.",
		impact:
			"Turns fragmented research and work sessions into durable, recoverable system memory.",
		proof: ["Private walkthrough available", "Architecture diagram coming soon"],
		tags: ["Claude API", "Python", "systemd", "bash"],
	},
	{
		name: "MERULOX",
		state: "active",
		date: "2026-06",
		description:
			"Personal portfolio and auto-updating log/feed pipeline. Static Astro site, keyboard-navigable, deployed on Cloudflare Pages with serverless feed proxies.",
		role: "Designed, built, and deployed.",
		impact:
			"Shows shipped work and recent progress without exposing private context.",
		proof: ["Live build", "Architecture diagram coming soon"],
		tags: ["Astro", "TypeScript", "CSS", "Cloudflare"],
	},
];
---

<Layout
	title="projects for employers | MERULOX"
	description="Selected systems built by Merulox."
	navItems={employerNavItems}
	homeHref="/employers"
	noindex={true}
>
	<style>
		.project-intro {
			margin-bottom: 28px;
			color: var(--muted);
			font-size: 13px;
		}

		.project-fields {
			display: grid;
			gap: 13px;
		}

		.project-field {
			display: grid;
			grid-template-columns: 72px minmax(0, 1fr);
			gap: 12px;
			align-items: baseline;
		}

		.project-field dt {
			color: var(--accent);
			font-family: "SFMono-Regular", Consolas, monospace;
			font-size: 10px;
			text-transform: uppercase;
		}

		.project-field dd {
			margin: 0;
			color: var(--muted);
			font-size: 13px;
			max-width: 58ch;
		}

		.project-proof {
			display: flex;
			flex-wrap: wrap;
			gap: 7px 14px;
			list-style: none;
			padding: 0;
		}

		.project-proof li {
			color: var(--muted);
			font-family: "SFMono-Regular", Consolas, monospace;
			font-size: 10px;
		}

		.project-proof li::before {
			content: "[ ]";
			color: var(--faint);
			margin-right: 6px;
		}

		.project-proof li:first-child::before {
			content: "[+]";
			color: var(--accent);
		}

		.project-stack {
			margin-top: 15px;
		}

		@media (max-width: 600px) {
			.project-field {
				grid-template-columns: 1fr;
				gap: 2px;
			}
		}
	</style>

	<h1>Projects</h1>
	<p class="project-intro">
		Selected systems with the build, operational value, and available evidence made
		explicit.
	</p>

	<div class="proj-list">
		{
			projects.map((p, i) => (
				<article class={`proj${i === 0 ? " open" : ""}`}>
					<button class="proj-head list-item" aria-expanded={i === 0 ? "true" : "false"}>
						<span class="proj-caret" aria-hidden="true">›</span>
						<span class="proj-name">{p.name}</span>
						<span class={`proj-state ${p.state}`}>{p.state}</span>
						<span class="proj-date">{p.date}</span>
					</button>
					<div class="proj-body">
						<dl class="project-fields">
							<div class="project-field">
								<dt>What</dt>
								<dd>{p.description}</dd>
							</div>
							<div class="project-field">
								<dt>Built</dt>
								<dd>{p.role}</dd>
							</div>
							<div class="project-field">
								<dt>Impact</dt>
								<dd>{p.impact}</dd>
							</div>
							<div class="project-field">
								<dt>Proof</dt>
								<dd>
									<ul class="project-proof">
										{p.proof.map((item) => <li>{item}</li>)}
									</ul>
								</dd>
							</div>
							<div class="project-field">
								<dt>Status</dt>
								<dd>{p.state} / {p.date}</dd>
							</div>
						</dl>
						<ul class="tag-list project-stack" aria-label={`${p.name} stack`}>
							{p.tags.map((t) => <li>{t}</li>)}
						</ul>
					</div>
				</article>
			))
		}
	</div>

	<script>
		document.querySelectorAll<HTMLButtonElement>(".proj-head").forEach((head) => {
			head.addEventListener("click", () => {
				const proj = head.closest(".proj")!;
				const open = proj.classList.toggle("open");
				head.setAttribute("aria-expanded", open ? "true" : "false");
			});
		});
	</script>
</Layout>
